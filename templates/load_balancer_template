upstream birdwatch {
        
        server {{ SERVER1 }};
        server {{ SERVER2 }};
}

server {
        listen 80 default_server;
        listen [::]:80 default_server;

        root /var/www/html;
        index index.html index.htm index.nginx-debian.html;

        server_name _;

        location / {
                proxy_pass http://birdwatch/;
        }


}